# ============================================================
# LLM API 配置（至少配一个）
# ============================================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini                              # 生成用模型
EMBEDDING_MODEL=text-embedding-3-small             # Embedding 模型

# ============================================================
# 可选：多 Provider 降级（litellm 支持）
# ============================================================
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# OLLAMA_BASE_URL=http://localhost:11434            # 本地 Ollama 降级

# ============================================================
# Rerank 模型
# ============================================================
# 本地模型路径（首次运行自动从 HuggingFace 下载）
RERANK_MODEL=BAAI/bge-reranker-base
# 可选：Cohere Rerank API（省本地 GPU/CPU）
# COHERE_API_KEY=

# ============================================================
# 向量存储
# ============================================================
CHROMA_PERSIST_DIR=./data/chroma

# ============================================================
# 缓存
# ============================================================
CACHE_DB_PATH=./data/cache.db

# ============================================================
# 检索参数
# ============================================================
RRF_K=60                                            # RRF 融合参数
VECTOR_TOP_K=20                                     # 向量检索候选数
BM25_TOP_K=20                                       # BM25 检索候选数
RERANK_TOP_K=5                                      # Rerank 后保留数量

# ============================================================
# Token 预算
# ============================================================
MAX_CONTEXT_TOKENS=4096                             # 上下文窗口总预算
SYSTEM_RESERVE_RATIO=0.30                           # 系统提示词+用户问题预留比例
CONTEXT_BUFFER_RATIO=0.05                           # 防抖动余量

# ============================================================
# Prompt 版本
# ============================================================
PROMPT_VERSION=v1

# ============================================================
# 追踪监控（可选，不配则跳过）
# ============================================================
# LANGFUSE_PUBLIC_KEY=pk-your-key
# LANGFUSE_SECRET_KEY=sk-your-key
# LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# 日志级别
# ============================================================
LOG_LEVEL=INFO
